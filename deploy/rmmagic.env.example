# rmmagic server environment — copy to deploy/rmmagic.env and fill in.
# deploy/rmmagic.env is gitignored; never commit real secrets.

# Postgres connection used by the server AND by migrations. Migrations
# need the privileged (schema-owning) role — NOT the restricted rmm_app
# role — so this DSN should be the owner connection.
RMM_DATABASE_URL=postgres://rmm:CHANGE_ME@localhost:5432/rmm?sslmode=disable

# 32-byte master key as 64 hex chars. Encrypts MFA secrets at rest.
# MUST stay stable across deploys or previously enrolled MFA secrets
# become unreadable. Generate once with:
#   head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n'
RMM_MASTER_KEY=CHANGE_ME_64_HEX_CHARS

# Set to "false" only for plain-http localhost; keep "true" behind TLS.
RMM_COOKIE_SECURE=true

# Listen address and roles for this instance.
RMM_LISTEN=:8080
ROLES=api,gateway,worker

# DB role the app connects as (RLS is enforced for this role).
RMM_APP_ROLE=rmm_app

# Remote-shell session recordings. Filesystem by default; persist this
# directory across deploys to keep playback. Leave empty to disable.
RMM_RECORDINGS_DIR=/var/lib/rmmserver/recordings
# To store recordings in S3/MinIO instead, set the endpoint (host:port)
# and credentials; the bucket is created if missing.
# RMM_S3_ENDPOINT=minio:9000
# RMM_S3_BUCKET=rmm-recordings
# RMM_S3_ACCESS_KEY=CHANGE_ME
# RMM_S3_SECRET_KEY=CHANGE_ME
# RMM_S3_USE_SSL=false

# Comma-separated Origin allowlist for the browser shell WebSocket.
# Empty = same-origin only (the secure default). Set for split-origin
# dev, e.g. http://localhost:5173
# RMM_ALLOWED_WS_ORIGINS=

# Restart strategy: auto | systemd | pidfile (auto picks systemd if a
# matching unit exists, else a backgrounded process under .run/).
# RUN_MODE=auto
# SERVICE_NAME=rmmserver
